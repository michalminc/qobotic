# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=dexio
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=dexio
POSTGRES_PORT=5432
DATABASE_URL="postgresql://dexio:changeme-strong-password@localhost:5432/dexio"

# ── Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Must be at least 32 characters.
JWT_SECRET="replace-with-strong-random-secret-at-least-32-chars"

# ── Redis (optional, for multi-instance rate limit) ───────
# Leave REDIS_URL unset to use in-memory rate limit (single-instance only).
REDIS_PASSWORD=changeme-strong-redis-password
REDIS_PORT=6379
REDIS_URL=

# ── Object storage (optional, S3-compatible) ──────────────
# If unset, uploads land on local public/uploads/ (fine for single-instance
# VPS with persistent volume; lost on serverless redeploys).
#
# Cloudflare R2 example:
#   S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_PUBLIC_URL=https://pub-<hash>.r2.dev          (or custom domain)
#
# Hetzner Object Storage example:
#   S3_ENDPOINT=https://nbg1.your-objectstorage.com  (or fsn1, hel1)
#   S3_REGION=nbg1
#   S3_PUBLIC_URL=https://<bucket>.nbg1.your-objectstorage.com
#
# AWS S3 example:
#   S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
#   S3_REGION=eu-central-1
#   S3_PUBLIC_URL=https://<bucket>.s3.eu-central-1.amazonaws.com
#
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_URL=
# Set to "true" for MinIO and some self-hosted providers that require path-style URLs.
S3_FORCE_PATH_STYLE=false
