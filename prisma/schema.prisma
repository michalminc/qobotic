generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum Role {
  ADMIN
  EDITOR
}

enum RobotCategory {
  HUMANOID
  INDUSTRIAL
  QUADRUPED
  RECEPTION
  CUSTOM
}

enum RobotStatus {
  PRODUCTION
  LAB
  COMING
  ARCHIVED
}

enum LeadType {
  SOFTWARE
  ROBOT_INQUIRY
  GENERAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  REJECTED
}

// ─── Models ───

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Robot {
  id           String        @id @default(cuid())
  slug         String        @unique
  name         String
  brand        String
  category     RobotCategory
  tagline      String
  description  String        @db.Text
  status       RobotStatus   @default(PRODUCTION)
  published    Boolean       @default(true)
  sortOrder    Int           @default(0)

  // Specs as flexible JSON: [{ label: "DOF", value: "42" }, ...]
  specs        Json          @default("[]")
  // Features as string array: ["Voice + Touch", "..."]
  features     Json          @default("[]")

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  images       RobotImage[]
  leads        Lead[]

  @@index([category])
  @@index([status])
  @@index([published])
}

model RobotImage {
  id        String @id @default(cuid())
  robotId   String
  robot     Robot  @relation(fields: [robotId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int    @default(0)

  @@index([robotId])
}

model Page {
  id          String   @id @default(cuid())
  slug        String   @unique  // "home", "intelligence", "operations", "lab", "fleet"
  title       String

  // Content as flexible JSON blob — sections, hero text, CTAs, etc.
  content     Json     @default("{}")

  // Optional SEO
  metaTitle   String?
  metaDesc    String?
  ogImage     String?

  published   Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model MediaAsset {
  id         String   @id @default(cuid())
  url        String
  filename   String
  mimeType   String
  size       Int       @default(0)
  width      Int?
  height     Int?
  alt        String?
  folder     String?   // e.g. "heroes", "robots", "lab"
  createdAt  DateTime  @default(now())

  @@index([folder])
}

model Lead {
  id          String     @id @default(cuid())
  type        LeadType
  status      LeadStatus @default(NEW)
  email       String
  name        String?
  company     String?
  message     String?    @db.Text
  robotId     String?
  robot       Robot?     @relation(fields: [robotId], references: [id], onDelete: SetNull)
  source      String?    // e.g. "fleet-card", "intelligence-cta"
  metadata    Json?      // additional context

  notes       String?    @db.Text  // internal admin notes
  contactedAt DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([type])
  @@index([robotId])
}
